rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Astuces (Tips)
    match /tips/{tipId} {
      // Tout le monde peut lire les astuces
      allow read: if true;
      
      // Seuls les utilisateurs connectés peuvent créer une astuce
      // On s'assure que l'auteur renseigné correspond à l'utilisateur connecté
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      
      // Seul l'auteur peut supprimer son astuce
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;

      // L'auteur peut modifier son astuce, mais les autres utilisateurs connectés peuvent uniquement liker/unliker (modifier uniquement 'likes' et 'likedBy')
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy'])
      );
    }
  }
}
